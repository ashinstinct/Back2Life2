{
  "version": 2,
  "cleanUrls": true,
  "functions": {
    "api/shorts/analyze.py": {
      "runtime": "@vercel/python",
      "maxDuration": 60
    },
    "api/shorts/render.py": {
      "runtime": "@vercel/python",
      "maxDuration": 60
    }
  },
  "headers": [
    {
      "source": "/icons/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/img/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/img/banners/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}